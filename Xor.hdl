// File name: projects/1/Xor.hdl
/**
 * Exclusive-or gate:
 * if ((a and Not(b)) or (Not(a) and b)) out = 1, else out = 0
 */
CHIP Xor {
    IN a, b;
    OUT out;

    PARTS:
    
    //// Replace this comment with your code.
    Nand(a=a, b=a, out=oa);Nand(a=b, b=b, out=ob);Nand(a=a, b=ob,out=x); Nand(a=oa, b=b, out=y); Nand(a=x, b=y, out=out);
} 