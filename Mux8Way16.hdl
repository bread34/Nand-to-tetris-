 Nand(a=n0SsS6, b=nS2SsS6, out=t13SsS6);
 Nand(a=n1SsS6, b=sel[2], out=t14SsS6);
 Nand(a=t13SsS6, b=t14SsS6, out=out[6]);

 // bit 7
 Nand(a=sel[0], b=sel[0], out=nS0SsS7);
 Nand(a=a[7], b=nS0SsS7, out=t1SsS7);
