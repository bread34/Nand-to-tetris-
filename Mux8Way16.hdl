// File name: projects/1/Mux8Way16.hdl
/**
 * 8-way 16-bit multiplexor:
 * out =  if sel = 000
 *       b if sel = 001
 *       c if sel = 010
 *       d if sel = 011
 *       e if sel = 100
 *       f if sel = 101
 *       g if sel = 110
 *       h if sel = 111
 */
CHIP Mux8Way16 {
    IN [16], b[16], c[16], d[16],
       e[16], f[16], g[16], h[16],
       sel[3];
    OUT out[16];

    PARTS:
    // bit 0(=t11_1, b=t12_1, out=n1_1);

// final layer
 // bit 0
 Nand(a=sel[0], b=sel[0], out=nS0SsS0);
 Nand(a=a[0], b=nS0SsS0, out=t1SsS0);
 Nand(a=b[0], b=sel[0], out=t2SsS0);
 Nand(a=t1SsS0, b=t2SsS0, out=m0SsS0);

 Nand(a=c[0], b=nS0SsS0, out=t3SsS0);
 Nand(a=d[0], b=sel[0], out=t4SsS0);
 Nand(a=t3SsS0, b=t4SsS0, out=m1SsS0);

 Nand(a=e[0], b=nS0SsS0, out=t5SsS0);
 Nand(a=f[0], b=sel[0], out=t6SsS0);
 Nand(a=t5SsS0, b=t6SsS0, out=m2SsS0);

 Nand(a=g[0], b=nS0SsS0, out=t7SsS0);
 Nand(a=h[0], b=sel[0], out=t8SsS0);
 Nand(a=t7SsS0, b=t8SsS0, out=m3SsS0);

 // second layer
 Nand(a=sel[1], b=sel[1], out=nS1SsS0);

 Nand(a=m0SsS0, b=nS1SsS0, out=t9SsS0);
 Nand(a=m1SsS0, b=sel[1], out=t10SsS0);
 Nand(a=t9SsS0, b=t10SsS0, out=n0SsS0);

 Nand(a=m2SsS0, b=nS1SsS0, out=t11SsS0);
 Nand(a=m3SsS0, b=sel[1], out=t12SsS0);
 Nand(a=t11SsS0, b=t12SsS0, out=n1SsS0);

 // final layer
 Nand(a=sel[2], b=sel[2], out=nS2SsS0);

 Nand(a=n0SsS0, b=nS2SsS0, out=t13SsS0);
 Nand(a=n1SsS0, b=sel[2], out=t14SsS0);
 Nand(a=t13SsS0, b=t14SsS0, out=out[0]);

 // bit 1
 Nand(a=sel[0], b=sel[0], out=nS0SsS1);
 Nand(a=a[1], b=nS0SsS1, out=t1SsS1);
 Nand(a=b[1], b=sel[0], out=t2SsS1);
 Nand(a=t1SsS1, b=t2SsS1, out=m0SsS1);

 Nand(a=c[1], b=nS0SsS1, out=t3SsS1);
 Nand(a=d[1], b=sel[0], out=t4SsS1);
 Nand(a=t3SsS1, b=t4SsS1, out=m1SsS1);

 Nand(a=e[1], b=nS0SsS1, out=t5SsS1);
 Nand(a=f[1], b=sel[0], out=t6SsS1);
 Nand(a=t5SsS1, b=t6SsS1, out=m2SsS1);

 Nand(a=g[1], b=nS0SsS1, out=t7SsS1);
 Nand(a=h[1], b=sel[0], out=t8SsS1);
 Nand(a=t7SsS1, b=t8SsS1, out=m3SsS1);

 // second layer
 Nand(a=sel[1], b=sel[1], out=nS1SsS1);

 Nand(a=m0SsS1, b=nS1SsS1, out=t9SsS1);
 Nand(a=m1SsS1, b=sel[1], out=t10SsS1);
 Nand(a=t9SsS1, b=t10SsS1, out=n0SsS1);

 Nand(a=m2SsS1, b=nS1SsS1, out=t11SsS1);
 Nand(a=m3SsS1, b=sel[1], out=t12SsS1);
 Nand(a=t11SsS1, b=t12SsS1, out=n1SsS1);

 // final layer
 Nand(a=sel[2], b=sel[2], out=nS2SsS1);

 Nand(a=n0SsS1, b=nS2SsS1, out=t13SsS1);
 Nand(a=n1SsS1, b=sel[2], out=t14SsS1);
 Nand(a=t13SsS1, b=t14SsS1, out=out[1]);

 // bit 2
 Nand(a=sel[0], b=sel[0], out=nS0SsS2);
 Nand(a=a[2], b=nS0SsS2, out=t1SsS2);
 Nand(a=b[2], b=sel[0], out=t2SsS2);
 Nand(a=t1SsS2, b=t2SsS2, out=m0SsS2);

 Nand(a=c[2], b=nS0SsS2, out=t3SsS2);
 Nand(a=d[2], b=sel[0], out=t4SsS2);
 Nand(a=t3SsS2, b=t4SsS2, out=m1SsS2);

 Nand(a=e[2], b=nS0SsS2, out=t5SsS2);
 Nand(a=f[2], b=sel[0], out=t6SsS2);
 Nand(a=t5SsS2, b=t6SsS2, out=m2SsS2);

 Nand(a=g[2], b=nS0SsS2, out=t7SsS2);
 Nand(a=h[2], b=sel[0], out=t8SsS2);
 Nand(a=t7SsS2, b=t8SsS2, out=m3SsS2);

 // second layer
 Nand(a=sel[1], b=sel[1], out=nS1SsS2);

 Nand(a=m0SsS2, b=nS1SsS2, out=t9SsS2);
 Nand(a=m1SsS2, b=sel[1], out=t10SsS2);
 Nand(a=t9SsS2, b=t10SsS2, out=n0SsS2);

 Nand(a=m2SsS2, b=nS1SsS2, out=t11SsS2);
 Nand(a=m3SsS2, b=sel[1], out=t12SsS2);
 Nand(a=t11SsS2, b=t12SsS2, out=n1SsS2);

 // final layer
 Nand(a=sel[2], b=sel[2], out=nS2SsS2);

 Nand(a=n0SsS2, b=nS2SsS2, out=t13SsS2);
 Nand(a=n1SsS2, b=sel[2], out=t14SsS2);
 Nand(a=t13SsS2, b=t14SsS2, out=out[2]);

 // bit 3
 Nand(a=sel[0], b=sel[0], out=nS0SsS3);
 Nand(a=a[3], b=nS0SsS3, out=t1SsS3);
 Nand(a=b[3], b=sel[0], out=t2SsS3);
 Nand(a=t1SsS3, b=t2SsS3, out=m0SsS3);

 Nand(a=c[3], b=nS0SsS3, out=t3SsS3);
 Nand(a=d[3], b=sel[0], out=t4SsS3);
 Nand(a=t3SsS3, b=t4SsS3, out=m1SsS3);

 Nand(a=e[3], b=nS0SsS3, out=t5SsS3);
 Nand(a=f[3], b=sel[0], out=t6SsS3);
 Nand(a=t5SsS3, b=t6SsS3, out=m2SsS3);

 Nand(a=g[3], b=nS0SsS3, out=t7SsS3);
 Nand(a=h[3], b=sel[0], out=t8SsS3);
 Nand(a=t7SsS3, b=t8SsS3, out=m3SsS3);

 // second layer
 Nand(a=sel[1], b=sel[1], out=nS1SsS3);

 Nand(a=m0SsS3, b=nS1SsS3, out=t9SsS3);
 Nand(a=m1SsS3, b=sel[1], out=t10SsS3);
 Nand(a=t9SsS3, b=t10SsS3, out=n0SsS3);

 Nand(a=m2SsS3, b=nS1SsS3, out=t11SsS3);
 Nand(a=m3SsS3, b=sel[1], out=t12SsS3);
 Nand(a=t11SsS3, b=t12SsS3, out=n1SsS3);

 // final layer
 Nand(a=sel[2], b=sel[2], out=nS2SsS3);

 Nand(a=n0SsS3, b=nS2SsS3, out=t13SsS3);
 Nand(a=n1SsS3, b=sel[2], out=t14SsS3);
 Nand(a=t13SsS3, b=t14SsS3, out=out[3]);

 // bit 4
 Nand(a=sel[0], b=sel[0], out=nS0SsS4);
 Nand(a=a[4], b=nS0SsS4, out=t1SsS4);
 Nand(a=b[4], b=sel[0], out=t2SsS4);
 Nand(a=t1SsS4, b=t2SsS4, out=m0SsS4);

 Nand(a=c[4], b=nS0SsS4, out=t3SsS4);
 Nand(a=d[4], b=sel[0], out=t4SsS4);
 Nand(a=t3SsS4, b=t4SsS4, out=m1SsS4);

 Nand(a=e[4], b=nS0SsS4, out=t5SsS4);
 Nand(a=f[4], b=sel[0], out=t6SsS4);
 Nand(a=t5SsS4, b=t6SsS4, out=m2SsS4);

 Nand(a=g[4], b=nS0SsS4, out=t7SsS4);
 Nand(a=h[4], b=sel[0], out=t8SsS4);
 Nand(a=t7SsS4, b=t8SsS4, out=m3SsS4);

 // second layer
 Nand(a=sel[1], b=sel[1], out=nS1SsS4);

 Nand(a=m0SsS4, b=nS1SsS4, out=t9SsS4);
 Nand(a=m1SsS4, b=sel[1], out=t10SsS4);
 Nand(a=t9SsS4, b=t10SsS4, out=n0SsS4);

 Nand(a=m2SsS4, b=nS1SsS4, out=t11SsS4);
 Nand(a=m3SsS4, b=sel[1], out=t12SsS4);
 Nand(a=t11SsS4, b=t12SsS4, out=n1SsS4);

 // final layer
 Nand(a=sel[2], b=sel[2], out=nS2SsS4);

 Nand(a=n0SsS4, b=nS2SsS4, out=t13SsS4);
 Nand(a=n1SsS4, b=sel[2], out=t14SsS4);
 Nand(a=t13SsS4, b=t14SsS4, out=out[4]);

 // bit 5
 Nand(a=sel[0], b=sel[0], out=nS0SsS5);
 Nand(a=a[5], b=nS0SsS5, out=t1SsS5);
 Nand(a=b[5], b=sel[0], out=t2SsS5);
 Nand(a=t1SsS5, b=t2SsS5, out=m0SsS5);

 Nand(a=c[5], b=nS0SsS5, out=t3SsS5);
 Nand(a=d[5], b=sel[0], out=t4SsS5);
 Nand(a=t3SsS5, b=t4SsS5, out=m1SsS5);

 Nand(a=e[5], b=nS0SsS5, out=t5SsS5);
 Nand(a=f[5], b=sel[0], out=t6SsS5);
 Nand(a=t5SsS5, b=t6SsS5, out=m2SsS5);

 Nand(a=g[5], b=nS0SsS5, out=t7SsS5);
 Nand(a=h[5], b=sel[0], out=t8SsS5);
 Nand(a=t7SsS5, b=t8SsS5, out=m3SsS5);

 // second layer
 Nand(a=sel[1], b=sel[1], out=nS1SsS5);

 Nand(a=m0SsS5, b=nS1SsS5, out=t9SsS5);
 Nand(a=m1SsS5, b=sel[1], out=t10SsS5);
 Nand(a=t9SsS5, b=t10SsS5, out=n0SsS5);

 Nand(a=m2SsS5, b=nS1SsS5, out=t11SsS5);
 Nand(a=m3SsS5, b=sel[1], out=t12SsS5);
 Nand(a=t11SsS5, b=t12SsS5, out=n1SsS5);

 // final layer
 Nand(a=sel[2], b=sel[2], out=nS2SsS5);

 Nand(a=n0SsS5, b=nS2SsS5, out=t13SsS5);
 Nand(a=n1SsS5, b=sel[2], out=t14SsS5);
 Nand(a=t13SsS5, b=t14SsS5, out=out[5]);

 // bit 6
 Nand(a=sel[0], b=sel[0], out=nS0SsS6);
 Nand(a=a[6], b=nS0SsS6, out=t1SsS6);
 Nand(a=b[6], b=sel[0], out=t2SsS6);
 Nand(a=t1SsS6, b=t2SsS6, out=m0SsS6);

 Nand(a=c[6], b=nS0SsS6, out=t3SsS6);
 Nand(a=d[6], b=sel[0], out=t4SsS6);
 Nand(a=t3SsS6, b=t4SsS6, out=m1SsS6);

 Nand(a=e[6], b=nS0SsS6, out=t5SsS6);
 Nand(a=f[6], b=sel[0], out=t6SsS6);
 Nand(a=t5SsS6, b=t6SsS6, out=m2SsS6);

 Nand(a=g[6], b=nS0SsS6, out=t7SsS6);
 Nand(a=h[6], b=sel[0], out=t8SsS6);
 Nand(a=t7SsS6, b=t8SsS6, out=m3SsS6);

 // second layer
 Nand(a=sel[1], b=sel[1], out=nS1SsS6);

 Nand(a=m0SsS6, b=nS1SsS6, out=t9SsS6);
 Nand(a=m1SsS6, b=sel[1], out=t10SsS6);
 Nand(a=t9SsS6, b=t10SsS6, out=n0SsS6);

 Nand(a=m2SsS6, b=nS1SsS6, out=t11SsS6);
 Nand(a=m3SsS6, b=sel[1], out=t12SsS6);
